# =============================================================================
# innexar-websitebr – variáveis de ambiente (referência para desenvolvimento e produção)
# =============================================================================
# Copie para .env e preencha. Em produção, garanta que as NEXT_PUBLIC_* estejam
# definidas no momento do build (docker compose build usa .env).
# =============================================================================

# --- Build (obrigatório para Portal + Checkout) ---
# Embutidas no bundle no build; alterar exige rebuild da imagem.
# A página de pagamento/checkout chama a API do Workspace (POST /api/public/checkout/start).
# As variáveis de pagamento (Mercado Pago, Stripe) ficam no BACKEND do innexar-workspace
# (backend/.env ou setup-wizard), não aqui.
NEXT_PUBLIC_USE_WORKSPACE_API=true
NEXT_PUBLIC_WORKSPACE_API_URL=https://api.innexar.com.br

# --- Runtime: Email (contato, checklist, respostas) ---
# Pelo menos uma opção: Resend OU SMTP OU OAuth2 (Google)
RESEND_API_KEY=
RESEND_FROM_EMAIL=contato@innexar.com.br
CONTACT_RECIPIENT_EMAIL=contato@innexar.com.br
ENABLE_AUTO_REPLY=true

# SMTP (alternativa ao Resend)
SMTP_HOST=mail.innexar.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contato@innexar.com.br
SMTP_PASSWORD=
SMTP_FROM_EMAIL=contato@innexar.com.br

# OAuth2 Google (opcional; prioridade sobre Resend/SMTP se configurado)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_FROM_EMAIL=

# --- Runtime: Conteúdo do site (opcional) ---
SITE_PHONE_BR=
SITE_WHATSAPP_BR=
SITE_ADDRESS_BR=
SALES_EMAIL=
SUPPORT_EMAIL=
COMPANY_NAME=

# --- Runtime: Prospector AI (URL da aplicação; fallback em código: prospectorai.innexar.com.br) ---
# NEXT_PUBLIC_PROSPECTOR_AI_URL=https://prospectorai.innexar.com.br

# --- Runtime: SEO e analytics (opcional) ---
NEXT_PUBLIC_SITE_URL=https://innexar.com.br
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_GOOGLE_ANALYTICS=
NEXT_PUBLIC_META_PIXEL_ID=

# --- Pagamento: Mercado Pago Bricks (OBRIGATÓRIO para checkout) ---
# Public Key do Mercado Pago. SEM esta chave, o checkout redireciona para a página do MP,
# onde o botão Pagar pode ficar desabilitado (404s no sandbox). Com a chave, o formulário
# fica integrado (Bricks) na nossa página e funciona corretamente.
# Obter em: https://www.mercadopago.com.br/developers > Suas integrações > Credenciais.
# Use a chave de PRODUÇÃO (APP_USR-...) ou TESTE (TEST-...) conforme o ambiente.
NEXT_PUBLIC_MP_PUBLIC_KEY=

# O Access Token e demais credenciais ficam no backend innexar-workspace:
# backend/.env (MP_ACCESS_TOKEN ou MERCADOPAGO_ACCESS_TOKEN, STRIPE_SECRET_KEY, etc.)
# ou via POST /api/workspace/system/setup-wizard (stripe/mercadopago no body).

# --- Server-side: Workspace API (ai/lead web-to-lead; opcional) ---
# Usado em rotas API quando NEXT_PUBLIC_* não está disponível no server.
# WORKSPACE_API_URL=https://api.innexar.com.br
